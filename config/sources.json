{
  "provider": "tdx-air-fids",
  "enable_live_fids": false,
  "airports": [
    "TPE",
    "TSA",
    "KHH",
    "RMQ",
    "HUN"
  ],
  "directions": [
    "Departure",
    "Arrival"
  ],
  "top": 200,
  "timeout_seconds": 20,
  "request_delay_seconds": 30.0,
  "retry_delay_seconds": 60.0,
  "max_retries": 2,
  "user_agent": "flight-cache-crawler/1.0 (+https://github.com/jiarong0423/flight)",
  "client_id_env": "TDX_CLIENT_ID",
  "client_secret_env": "TDX_CLIENT_SECRET",
  "mock_fallback": true,
  "offer_routes": [
    "TPE-NRT",
    "TPE-ICN",
    "TPE-HKG",
    "TSA-KNH"
  ],
  "offer_lookahead_days": 30,
  "schedule_lookahead_days": 120,
  "offer_mock_fallback": true,
  "ticket_offer_sources": [
    {
      "name": "amadeus-flight-offers",
      "type": "amadeus",
      "enabled": false,
      "environment": "test",
      "client_id_env": "AMADEUS_CLIENT_ID",
      "client_secret_env": "AMADEUS_CLIENT_SECRET",
      "currency": "TWD",
      "adults": 1,
      "max_results": 10
    },
    {
      "name": "example-json-ticket-provider",
      "type": "json",
      "enabled": false,
      "url": "https://example.com/api/search?origin={origin}&destination={destination}&date={date}",
      "items_path": "items",
      "fields": {
        "price": "price",
        "currency": "currency",
        "flight_number": "flight_number",
        "airline_id": "airline",
        "departure_time": "departure_time",
        "arrival_time": "arrival_time",
        "duration_minutes": "duration_minutes",
        "transfer_count": "transfer_count",
        "baggage_checked_weight_kg": "baggage.checked_kg",
        "baggage_checked_pieces": "baggage.checked_pieces",
        "baggage_carry_on_weight_kg": "baggage.carry_on_kg",
        "fare_brand": "fare_brand",
        "booking_url": "booking_url"
      }
    },
    {
      "name": "example-csv-ticket-provider",
      "type": "csv",
      "enabled": false,
      "url": "https://example.com/ticket-offers.csv",
      "fields": {
        "origin": "origin",
        "destination": "destination",
        "departure_date": "departure_date",
        "price": "price",
        "currency": "currency",
        "flight_number": "flight_number",
        "airline_id": "airline_id",
        "transfer_count": "transfer_count",
        "baggage_checked_weight_kg": "checked_baggage_kg"
      }
    },
    {
      "name": "example-html-ticket-provider",
      "type": "html_regex",
      "enabled": false,
      "url": "https://example.com/flights/{origin}/{destination}/{date}",
      "price_regex": "price[^0-9]*(?P<price>[0-9,]+)",
      "flight_number_regex": "(?P<flight>[A-Z]{2}[0-9]{2,4})",
      "baggage_regex": "(?P<weight>[0-9]{1,2})\\s*kg"
    }
  ]
}

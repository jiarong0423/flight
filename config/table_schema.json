{
  "schema_version": 2,
  "updated_at": "2026-06-26",
  "strategy": "fixed schedule + minimal change overlay + lookup tables",
  "tables": {
    "airports": {
      "file": "data/tables.json",
      "primary_key": "airport_id",
      "columns": ["airport_id", "airport_name_zh", "airport_name_en", "country", "flag"]
    },
    "airlines": {
      "file": "data/tables.json",
      "primary_key": "airline_id",
      "columns": ["airline_id", "airline_name_zh", "airline_name_en", "icon_url", "rule_status", "rule_source_url"]
    },
    "routes": {
      "file": "data/tables.json",
      "primary_key": "route",
      "columns": ["route", "origin", "destination"]
    },
    "fixed_schedule": {
      "file": "data/schedule.json",
      "primary_key": "schedule_id",
      "columns": [
        "schedule_id",
        "route",
        "origin",
        "destination",
        "flight_date",
        "weekday",
        "airline_id",
        "flight_number",
        "departure_time",
        "arrival_time",
        "duration_minutes",
        "transfer_count",
        "transfer_airports",
        "source"
      ]
    },
    "change_overlay": {
      "file": "data/changes.json",
      "primary_key": "change_id",
      "columns": [
        "route",
        "origin",
        "destination",
        "flight_date",
        "flight_number",
        "airline_id",
        "change_id",
        "change_type",
        "price",
        "currency",
        "baggage_checked_weight_kg",
        "baggage_checked_pieces",
        "baggage_carry_on_weight_kg",
        "transfer_count",
        "transfer_airports",
        "booking_url",
        "changed_fields",
        "source"
      ]
    },
    "ticket_offers": {
      "file": "data/offers.json",
      "primary_key": "id",
      "columns": [
        "route",
        "origin",
        "destination",
        "departure_date",
        "flight_number",
        "airline_id",
        "departure_time",
        "arrival_time",
        "duration_minutes",
        "id",
        "price",
        "currency",
        "transfer_count",
        "transfer_airports",
        "baggage_checked_weight_kg",
        "baggage_checked_pieces",
        "baggage_carry_on_weight_kg",
        "booking_url",
        "source"
      ]
    }
  }
}
